{
  "title": "Negócio — Fluxo de Caixa",
  "uid": "negocio",
  "tags": ["negocio", "fluxocaixa"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Lançamentos (última hora)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "increase(http_server_requests_seconds_count{job=\"lancamentos\",uri=\"/registros\",method=\"POST\",outcome=\"SUCCESS\"}[1h])", "legendFormat": "total", "instant": true }],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] } } }
    },
    {
      "id": 2, "type": "stat", "title": "Mensagens Dead-lettered (total)",
      "description": "Total acumulado de mensagens enviadas à DLQ por rejeição, expiração ou limite de entrega.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "sum(rabbitmq_global_messages_dead_lettered_rejected_total + rabbitmq_global_messages_dead_lettered_expired_total + rabbitmq_global_messages_dead_lettered_maxlen_total + rabbitmq_global_messages_dead_lettered_delivery_limit_total)", "legendFormat": "dead-lettered", "instant": true }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Cache Hit Rate (Redis)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "rate(cache_gets_total{job=\"consolidado\",result=\"hit\"}[5m]) / clamp_min(rate(cache_gets_total{job=\"consolidado\",result!=\"pending\"}[5m]), 1e-10)", "legendFormat": "hit rate", "instant": true }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.9 }] } } }
    },
    {
      "id": 4, "type": "stat", "title": "Lançamentos processados (total)",
      "description": "Total de eventos de lançamento publicados no RabbitMQ desde o início.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "rabbitmq_queue_messages_published_total", "legendFormat": "total", "instant": true }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Lançamentos por minuto",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(http_server_requests_seconds_count{job=\"lancamentos\",uri=\"/registros\",method=\"POST\",outcome=\"SUCCESS\"}[1m]) * 60", "legendFormat": "registros/min (201)" },
        { "datasource": "Prometheus", "expr": "rate(http_server_requests_seconds_count{job=\"lancamentos\",uri=\"/registros\",method=\"POST\",outcome=\"CLIENT_ERROR\"}[1m]) * 60", "legendFormat": "duplicados/min (409)" },
        { "datasource": "Prometheus", "expr": "rate(http_server_requests_seconds_count{job=\"lancamentos\",uri=\"/registros\",method=\"GET\"}[1m]) * 60", "legendFormat": "consultas/min" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqpm", "custom": { "lineWidth": 2 } }, "overrides": [
        { "matcher": { "id": "byName", "options": "registros/min (201)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "duplicados/min (409)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
        { "matcher": { "id": "byName", "options": "consultas/min" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] }
      ]}
    },
    {
      "id": 6, "type": "timeseries", "title": "Eventos RabbitMQ por minuto",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(rabbitmq_global_messages_received_total[1m]) * 60", "legendFormat": "publicados/min" },
        { "datasource": "Prometheus", "expr": "rate(rabbitmq_global_messages_delivered_total[1m]) * 60", "legendFormat": "consumidos/min" },
        { "datasource": "Prometheus", "expr": "rate(rabbitmq_global_messages_acknowledged_total[1m]) * 60", "legendFormat": "acked/min" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqpm", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 7, "type": "timeseries", "title": "Cache Hit Rate — tendência (Redis)",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(redis_keyspace_hits_total[1m]) / clamp_min(rate(redis_keyspace_hits_total[1m]) + rate(redis_keyspace_misses_total[1m]), 1e-10) * 100", "legendFormat": "hit rate %" },
        { "datasource": "Prometheus", "expr": "rate(redis_keyspace_hits_total[1m]) * 60", "legendFormat": "hits/min" },
        { "datasource": "Prometheus", "expr": "rate(redis_keyspace_misses_total[1m]) * 60", "legendFormat": "misses/min" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }, "overrides": [
        { "matcher": { "id": "byName", "options": "hit rate %" }, "properties": [{ "id": "unit", "value": "percent" }, { "id": "custom.axisPlacement", "value": "right" }, { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
      ]}
    },
    {
      "id": 8, "type": "timeseries", "title": "Latência dos Lançamentos (p50/p95/p99)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"lancamentos\",uri=\"/registros\",method=\"POST\"}[5m])))", "legendFormat": "p50" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"lancamentos\",uri=\"/registros\",method=\"POST\"}[5m])))", "legendFormat": "p95" },
        { "datasource": "Prometheus", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"lancamentos\",uri=\"/registros\",method=\"POST\"}[5m])))", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 1 }] } } }
    }
  ]
}
