{
  "title": "Negócio — Fluxo de Caixa",
  "uid": "negocio",
  "tags": ["negocio", "fluxocaixa"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Lançamentos (última hora)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "increase(lancamentos_registrados_total[1h])", "legendFormat": "total" }],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] } } }
    },
    {
      "id": 2, "type": "stat", "title": "Eventos na DLQ",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "sum(rabbitmq_queue_messages{queue=~\".*\\\\.dlq\"})", "legendFormat": "DLQ" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 3, "type": "stat", "title": "Cache Hit Rate",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "rate(consolidacao_cache_hits_total[5m]) / (rate(consolidacao_cache_hits_total[5m]) + rate(consolidacao_cache_misses_total[5m]))", "legendFormat": "hit rate" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.9 }] } } }
    },
    {
      "id": 4, "type": "stat", "title": "Valor Total Registrado (hoje)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "increase(lancamentos_valor_total[24h])", "legendFormat": "BRL" }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "currencyBRL", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } }
    },
    {
      "id": 5, "type": "timeseries", "title": "Lançamentos por minuto",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(lancamentos_registrados_total{tipo=\"credito\"}[1m])", "legendFormat": "crédito" },
        { "datasource": "Prometheus", "expr": "rate(lancamentos_registrados_total{tipo=\"debito\"}[1m])", "legendFormat": "débito" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }, "overrides": [{ "matcher": { "id": "byName", "options": "crédito" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }, { "matcher": { "id": "byName", "options": "débito" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }] }
    },
    {
      "id": 6, "type": "timeseries", "title": "Eventos processados por minuto",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        { "datasource": "Prometheus", "expr": "rate(eventos_publicados_total[1m])", "legendFormat": "publicados" },
        { "datasource": "Prometheus", "expr": "rate(eventos_consumidos_total{status=\"ok\"}[1m])", "legendFormat": "consumidos OK" },
        { "datasource": "Prometheus", "expr": "rate(eventos_consumidos_total{status=\"erro\"}[1m])", "legendFormat": "consumidos ERRO" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
