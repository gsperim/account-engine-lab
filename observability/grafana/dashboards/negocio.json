    {
      "id": 2,
      "type": "stat",
      "title": "Saldo Líquido (período)",
      "description": "Créditos acumulados menos débitos acumulados no período selecionado",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 5,
        "h": 4
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "instant": true,
          "expr": "increase(lancamentos_valor_reais_total{job=\"lancamentos\",tipo=\"CREDITO\"}[$__range]) - increase(lancamentos_valor_reais_total{job=\"lancamentos\",tipo=\"DEBITO\"}[$__range])",
          "legendFormat": "saldo"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyBRL",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
