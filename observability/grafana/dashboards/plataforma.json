{
  "title": "Plataforma — Fluxo de Caixa",
  "tags": ["fluxocaixa", "plataforma"],
  "uid": "plataforma-fluxo-de-caixa",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "PostgreSQL — Conexões ativas",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "pg_stat_activity_count{datname=\"lancamentos\"}",
          "legendFormat": "lancamentos"
        },
        {
          "expr": "pg_stat_activity_count{datname=\"consolidado\"}",
          "legendFormat": "consolidado"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "PostgreSQL — Transações/s",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"lancamentos\"}[1m]) + rate(pg_stat_database_xact_rollback{datname=\"lancamentos\"}[1m])",
          "legendFormat": "lancamentos commits+rollbacks/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"consolidado\"}[1m]) + rate(pg_stat_database_xact_rollback{datname=\"consolidado\"}[1m])",
          "legendFormat": "consolidado commits+rollbacks/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 3,
      "title": "Redis — Memória usada",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "used"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      }
    },
    {
      "id": 4,
      "title": "Redis — Hit Rate (%)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "100 * rate(redis_keyspace_hits_total[5m]) / (rate(redis_keyspace_hits_total[5m]) + rate(redis_keyspace_misses_total[5m]) + 0.001)",
          "legendFormat": "hit rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 70 },
              { "color": "green", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Redis — Chaves / Evictions",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "redis_db_keys",
          "legendFormat": "chaves"
        },
        {
          "expr": "increase(redis_evicted_keys_total[5m])",
          "legendFormat": "evictions (5m)"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "title": "RabbitMQ — Mensagens nas filas",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages",
          "legendFormat": "{{queue}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 7,
      "title": "RabbitMQ — Taxa de publish/consume (msg/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(rabbitmq_channel_messages_published_total[1m])",
          "legendFormat": "publish/s"
        },
        {
          "expr": "rate(rabbitmq_channel_messages_delivered_total[1m])",
          "legendFormat": "delivered/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "msgps" }
      }
    },
    {
      "id": 8,
      "title": "Traefik — Requisições/s por rota",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (router) (rate(traefik_router_requests_total[1m]))",
          "legendFormat": "{{router}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 9,
      "title": "Traefik — Erros 4xx/5xx",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (code) (rate(traefik_router_requests_total{code=~\"[45]..\"}[1m]))",
          "legendFormat": "HTTP {{code}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 10,
      "title": "Containers — Status (Blackbox probe)",
      "type": "table",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "probe_success",
          "legendFormat": "{{instance}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
                  { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}
