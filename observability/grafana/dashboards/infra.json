{
  "title": "Infraestrutura — Fluxo de Caixa",
  "uid": "infra",
  "tags": [
    "infra",
    "fluxocaixa"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Throughput (req/s)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (job) (rate(http_server_requests_seconds_count[1m]))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Taxa de Erro (%)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{outcome=\"SERVER_ERROR\"}[1m])) / clamp_min(sum by (job) (rate(http_server_requests_seconds_count[1m])), 1e-10) * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latência p50 / p95 / p99",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum by (job, le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p50"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (job, le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p95"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{job}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Probe Blackbox — tempo de resposta",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "probe_duration_seconds",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Probe — Status dos endpoints",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "probe_success",
          "legendFormat": "{{instance}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ]
        }
      }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Host — CPU / Memória / Disco / Rede",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Host — CPU (%)",
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "cpu utilizado"
        },
        {
          "datasource": "Prometheus",
          "expr": "avg by (instance) (rate(node_cpu_seconds_total{mode=\"iowait\"}[5m])) * 100",
          "legendFormat": "iowait"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Host — Memória (%)",
      "gridPos": {
        "x": 12,
        "y": 25,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
          "legendFormat": "memória usada"
        },
        {
          "datasource": "Prometheus",
          "expr": "node_memory_Buffers_bytes / node_memory_MemTotal_bytes * 100",
          "legendFormat": "buffers"
        },
        {
          "datasource": "Prometheus",
          "expr": "node_memory_Cached_bytes / node_memory_MemTotal_bytes * 100",
          "legendFormat": "cached"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 33,
      "type": "stat",
      "title": "Host — Memória Total / Disponível",
      "gridPos": {
        "x": 0,
        "y": 33,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "total",
          "instant": true
        },
        {
          "datasource": "Prometheus",
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "disponível",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 34,
      "type": "stat",
      "title": "Host — Load Average",
      "gridPos": {
        "x": 8,
        "y": 33,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "node_load1",
          "legendFormat": "1m",
          "instant": true
        },
        {
          "datasource": "Prometheus",
          "expr": "node_load5",
          "legendFormat": "5m",
          "instant": true
        },
        {
          "datasource": "Prometheus",
          "expr": "node_load15",
          "legendFormat": "15m",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 4
              },
              {
                "color": "red",
                "value": 8
              }
            ]
          }
        }
      }
    },
    {
      "id": 35,
      "type": "gauge",
      "title": "Host — Disco Raiz (% usado)",
      "gridPos": {
        "x": 16,
        "y": 33,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} - node_filesystem_free_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} * 100",
          "legendFormat": "/ usado",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "id": 36,
      "type": "timeseries",
      "title": "Host — Disco I/O (bytes/s)",
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(node_disk_read_bytes_total{device!~\"loop.*\"}[5m])",
          "legendFormat": "leitura — {{device}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(node_disk_written_bytes_total{device!~\"loop.*\"}[5m])",
          "legendFormat": "escrita — {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 37,
      "type": "timeseries",
      "title": "Host — Rede (bytes/s)",
      "gridPos": {
        "x": 12,
        "y": 37,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|br-.*|veth.*\"}[5m])",
          "legendFormat": "recebido — {{device}}"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|br-.*|veth.*\"}[5m])",
          "legendFormat": "enviado — {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Recursos — CPU / Memória / JVM",
      "gridPos": {
        "x": 0,
        "y": 45,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "CPU — Sistema (%)",
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "system_cpu_usage{job=~\"lancamentos|consolidado|keycloak\"} * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "CPU — Processo (%)",
      "gridPos": {
        "x": 12,
        "y": 46,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_cpu_usage{job=~\"lancamentos|consolidado|keycloak\"} * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "JVM Heap — Usado vs Máximo",
      "gridPos": {
        "x": 0,
        "y": 54,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (job) (jvm_memory_used_bytes{area=\"heap\", job=~\"lancamentos|consolidado\"})",
          "legendFormat": "{{job}} usado"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum by (job) (jvm_memory_max_bytes{area=\"heap\", job=~\"lancamentos|consolidado\"})",
          "legendFormat": "{{job}} máx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Memória RSS dos Processos",
      "gridPos": {
        "x": 12,
        "y": 54,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "process_resident_memory_bytes{job=~\"lancamentos|consolidado|keycloak\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "JVM — Threads Vivas",
      "gridPos": {
        "x": 0,
        "y": 62,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "jvm_threads_live_threads{job=~\"lancamentos|consolidado\"}",
          "legendFormat": "{{job}} live"
        },
        {
          "datasource": "Prometheus",
          "expr": "jvm_threads_daemon_threads{job=~\"lancamentos|consolidado\"}",
          "legendFormat": "{{job}} daemon"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "JVM — GC Pause (max, ms)",
      "gridPos": {
        "x": 12,
        "y": 62,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "max by (job, gc) (jvm_gc_pause_seconds_max{job=~\"lancamentos|consolidado\"}) * 1000",
          "legendFormat": "{{job}} — {{gc}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      }
    },
    {
      "id": 27,
      "type": "gauge",
      "title": "Disco — % Utilizado",
      "gridPos": {
        "x": 0,
        "y": 70,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "(1 - disk_free_bytes / disk_total_bytes) * 100",
          "legendFormat": "{{job}}",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "id": 28,
      "type": "stat",
      "title": "Disco — Livre / Total",
      "gridPos": {
        "x": 12,
        "y": 70,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "disk_free_bytes",
          "legendFormat": "{{job}} livre",
          "instant": true
        },
        {
          "datasource": "Prometheus",
          "expr": "disk_total_bytes",
          "legendFormat": "{{job}} total",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    }
  ]
}