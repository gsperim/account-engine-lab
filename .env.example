# Copie este arquivo para .env e ajuste os valores para o seu ambiente.
# O .env nunca deve ser versionado (está no .gitignore).

# ── API Gateway ────────────────────────────────────────────────────────────
GATEWAY_PORT=8090

# ── PostgreSQL — Lançamentos ───────────────────────────────────────────────
POSTGRES_LANCAMENTOS_DB=lancamentos
POSTGRES_LANCAMENTOS_USER=lancamentos
POSTGRES_LANCAMENTOS_PASSWORD=changeme

# ── PostgreSQL — Consolidação ──────────────────────────────────────────────
POSTGRES_CONSOLIDADO_DB=consolidado
POSTGRES_CONSOLIDADO_USER=consolidado
POSTGRES_CONSOLIDADO_PASSWORD=changeme

# ── RabbitMQ ───────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Outbox Relay ───────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL=500ms

# ── Keycloak ───────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme          # obrigatório — sem padrão inseguro em prod
PDV_CLIENT_SECRET=pdv-secret-changeme    # secret do client pdv-service
# JWKS URL para o API Gateway validar tokens:
# http://keycloak:8080/realms/fluxocaixa/protocol/openid-connect/certs

# ── Alertmanager — Dev (Telegram) ──────────────────────────────────────────
# Setup: @BotFather → /newbot → copie o token
# Chat ID: https://api.telegram.org/bot<TOKEN>/getUpdates → campo chat.id
TELEGRAM_BOT_TOKEN=changeme
TELEGRAM_CHAT_ID=changeme
# Produção (Slack + PagerDuty — ver comentários no alertmanager.yml):
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE/ME
# PAGERDUTY_INTEGRATION_KEY=changeme

# ── Geral ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
